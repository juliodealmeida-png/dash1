# Guardline API (TypeScript) — copie para .env

PORT=3002
NODE_ENV=development

# CORS — origens do dashboard/backend principal
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://127.0.0.1:3001

# Supabase (obrigatório para DB + Realtime no servidor)
SUPABASE_URL=https://xxxx.supabase.co
# Use uma das duas (alias aceite pelo código):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_KEY=

# Segredos webhook (header X-Guardline-Secret ou Authorization: Bearer ...)
N8N_WEBHOOK_SECRET=
# Sink WF06 → POST /api/webhooks/wf06-result (pode ser o mesmo valor que n8n)
DASHBOARD_WEBHOOK_SECRET=

# HubSpot PAT (opcional — sync principal via n8n WF08)
HUBSPOT_PAT=

# Groq (Llama) — proxy em POST /api/ai/chat + parse threat intel (nunca no browser)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Jobs opcionais: geocode leads + ingest RSS threat intel na subida e por intervalo
# ENABLE_FRAUD_MAP_JOBS=1

# n8n Cloud — base sem /webhook (o código acrescenta /webhook/...)
N8N_BASE_URL=https://guardline.app.n8n.cloud
N8N_API_KEY=

# Caminhos webhook n8n (relativos a N8N_BASE_URL se usar path completo no trigger)
N8N_PATH_WF06=wf06-guardline-autonomous-revenue-system-v52-execution-ready
N8N_PATH_WF07_BATCH=wf07-guardline-batch-intake-v1
N8N_PATH_WF08=

# JWT — se mais tarde alinhar auth com o dashboard Express legado (opcional)
# JWT_SECRET=
