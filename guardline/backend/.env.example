# Após `npm run db:seed`: login UI demo@guardline.com / guardline123

# ── SERVER ──
PORT=3001
NODE_ENV=development
# Várias origens separadas por vírgula se usar `npx serve` noutra porta (ex.: 5173)
# Inclua aqui o domínio do Cloudflare Pages (ex.: https://seu-projeto.pages.dev) e/ou seu domínio custom.
FRONTEND_URL=http://localhost:3001,http://localhost:5173,http://localhost:5500,http://127.0.0.1:5173,https://seu-projeto.pages.dev
# Data API TypeScript (produção/Railway: URL privada ou pública do serviço `api`)
DATA_API_BASE_URL=http://localhost:3002
GUARDLINE_DATA_API_BASE=http://localhost:3002

# ── DATABASE ──
# Local/produção (Railway): PostgreSQL
DATABASE_URL="postgresql://user:pass@host:5432/guardline?schema=public"

# ── AUTH ──
JWT_SECRET=seu_jwt_secret_muito_longo_e_seguro_aqui_minimo_64_chars_para_desenvolvimento_seguro_xx
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=outro_secret_diferente_do_jwt_tambem_longo_para_refresh_tokens_guardline_xx
REFRESH_TOKEN_EXPIRES_IN=30d

# ── NVIDIA NIMs (Julio AI) ── https://integrate.api.nvidia.com
NVIDIA_API_KEY=nvapi-...
# Modelo padrão: moonshotai/kimi-k2.5 (suporta contexto longo)
JULIO_MODEL=moonshotai/kimi-k2.5
# Compatibilidade retroativa: ANTHROPIC_API_KEY também aceito como fallback
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AI PERFORMANCE TUNING ──
# Máximo de tokens por resposta do Julio AI (1024 = rápido, 2048 = completo)
AI_MAX_TOKENS=1024
# Timeout HTTP para chamadas NVIDIA NIMs (ms)
AI_HTTP_TIMEOUT_MS=20000
# TTL do cache de contexto de pipeline do Julio (ms) — 30s reduz chamadas ao DB
JULIO_CONTEXT_CACHE_MS=30000
# NewsAPI.org key para notícias de mercado no enriquecimento de leads
NEWS_API_KEY=

# ── SOCKET / REALTIME ──
# true = permite conexão sem JWT (apenas dev)
SOCKET_AUTH_OPTIONAL=false
# false = desliga simulação automática de fraudes
FRAUD_SIMULATION=true

# ── GMAIL ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/integrations/gmail/callback
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── SLACK ──
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ALERTS=#revenue-alerts
SLACK_CHANNEL_DAILY=#julio-daily

# ── N8N ──
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ── WHATSAPP (Twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── HUBSPOT ──
# Private App token: https://app.hubspot.com/private-apps
HUBSPOT_PAT=pat-na1-...
# Secret para validar assinaturas HMAC dos webhooks (configure no HubSpot app settings)
HUBSPOT_WEBHOOK_SECRET=

# ── ENCRYPTION ──
ENCRYPTION_KEY=12345678901234567890123456789012
