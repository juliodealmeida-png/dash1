# Após `npm run db:seed`: login UI demo@guardline.com / guardline123

# ── SERVER ──
PORT=3001
NODE_ENV=development
# Várias origens separadas por vírgula se usar `npx serve` noutra porta (ex.: 5173)
FRONTEND_URL=http://localhost:3001,http://localhost:5173,http://localhost:5500,http://127.0.0.1:5173
# Data API TypeScript (produção/Railway: URL privada ou pública do serviço `api`)
DATA_API_BASE_URL=http://localhost:3002
GUARDLINE_DATA_API_BASE=http://localhost:3002

# ── DATABASE ──
DATABASE_URL="file:./guardline.db"
# Produção: DATABASE_URL="postgresql://user:pass@host:5432/guardline"

# ── AUTH ──
JWT_SECRET=seu_jwt_secret_muito_longo_e_seguro_aqui_minimo_64_chars_para_desenvolvimento_seguro_xx
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=outro_secret_diferente_do_jwt_tambem_longo_para_refresh_tokens_guardline_xx
REFRESH_TOKEN_EXPIRES_IN=30d

# ── ANTHROPIC (Julio AI) ──
ANTHROPIC_API_KEY=sk-ant-api03-...
# Ex.: claude-sonnet-4-5 ou claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── SOCKET / REALTIME ──
# true = permite conexão sem JWT (apenas dev)
SOCKET_AUTH_OPTIONAL=false
# false = desliga simulação automática de fraudes
FRAUD_SIMULATION=true

# ── GMAIL ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/integrations/gmail/callback
GMAIL_REFRESH_TOKEN=

# ── SLACK ──
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ALERTS=#revenue-alerts
SLACK_CHANNEL_DAILY=#julio-daily

# ── N8N ──
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ── WHATSAPP (Twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── ENCRYPTION ──
ENCRYPTION_KEY=12345678901234567890123456789012
